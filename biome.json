{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "files": {
        "include": [
            "*.js",
            "src/**/*.[jt]s",
            "test/**/*.[jt]s"
        ],
        "ignore": ["**/package.json", "**/node_modules"]
    },
    "formatter": {
        "lineWidth": 120,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "javascript": {
        "formatter": {
            "trailingCommas": "es5",
            "bracketSameLine": true,
            "quoteStyle": "single"
        }
    }
}
